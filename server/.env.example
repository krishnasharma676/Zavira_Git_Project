# ─── Zavira Server — Environment Variables ────────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit the actual .env file to git.

# ─── App ─────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=8000

# ─── CORS (comma-separated list of allowed frontend origins) ─────────────────
CORS_ORIGIN=https://yourdomain.com,https://www.yourdomain.com

# ─── Database (PostgreSQL via Prisma) ────────────────────────────────────────
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public

# ─── JWT Secrets (use long random strings — min 32 chars) ────────────────────
ACCESS_TOKEN_SECRET=replace_with_a_very_long_random_secret_string
REFRESH_TOKEN_SECRET=replace_with_another_very_long_random_secret_string
ACCESS_TOKEN_EXPIRY=15m
REFRESH_TOKEN_EXPIRY=7d

# ─── Admin Seed (used to auto-create the first admin account on startup) ──────
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=YourStrongAdminPassword123!

# ─── Firebase Admin SDK ───────────────────────────────────────────────────────
# Download from: Firebase Console → Project Settings → Service Accounts
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com

# ─── Razorpay ─────────────────────────────────────────────────────────────────
# Get from: https://dashboard.razorpay.com → Settings → API Keys
RAZORPAY_KEY_ID=rzp_live_XXXXXXXXXXXXXXXX
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# ─── Shiprocket ───────────────────────────────────────────────────────────────
# Your Shiprocket account credentials
SHIPROCKET_EMAIL=your@email.com
SHIPROCKET_PASSWORD=your_shiprocket_password
# Set to "true" on staging to use mock shipments (no real API calls)
SHIPROCKET_TEST_MODE=false

# ─── Cloudinary ───────────────────────────────────────────────────────────────
# Get from: https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
